#:import MDTopAppBar kivymd.uix.toolbar.MDTopAppBar
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDSegmentedControl kivymd.uix.segmentedcontrol.MDSegmentedControl
#:import MDSegmentedControlItem kivymd.uix.segmentedcontrol.MDSegmentedControlItem

<AddTransactionScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        MDTopAppBar:
            title: "Add Transaction"
            elevation: 2
            left_action_items: [["arrow-left", lambda x: root.go_back()]]

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                padding: "16dp"
                spacing: "16dp"

                # ── Type toggle ────────────────────────────────────────────
                MDBoxLayout:
                    adaptive_height: True
                    spacing: "8dp"

                    MDRaisedButton:
                        id: btn_expense
                        text: "Expense"
                        size_hint_x: 1
                        on_release: root.set_type("expense")
                        md_bg_color: app.theme_cls.primary_color

                    MDRaisedButton:
                        id: btn_income
                        text: "Income"
                        size_hint_x: 1
                        on_release: root.set_type("income")
                        md_bg_color: app.theme_cls.divider_color

                # ── Amount ────────────────────────────────────────────────
                MDTextField:
                    id: amount_field
                    hint_text: "Amount (₹)"
                    input_filter: "float"
                    mode: "rectangle"
                    size_hint_y: None
                    height: "56dp"

                # ── Category ─────────────────────────────────────────────
                MDTextField:
                    id: category_field
                    hint_text: "Category (tap to choose)"
                    mode: "rectangle"
                    readonly: True
                    size_hint_y: None
                    height: "56dp"
                    on_focus: if self.focus: root.open_category_menu()

                # ── Date ─────────────────────────────────────────────────
                MDTextField:
                    id: date_field
                    hint_text: "Date"
                    mode: "rectangle"
                    readonly: True
                    size_hint_y: None
                    height: "56dp"
                    on_focus: if self.focus: root.open_date_picker()

                # ── Note ─────────────────────────────────────────────────
                MDTextField:
                    id: note_field
                    hint_text: "Note (optional)"
                    mode: "rectangle"
                    size_hint_y: None
                    height: "56dp"

                # ── Save ─────────────────────────────────────────────────
                MDRaisedButton:
                    text: "Save"
                    size_hint_x: 1
                    height: "48dp"
                    on_release: root.save()
                    md_bg_color: app.theme_cls.primary_color
