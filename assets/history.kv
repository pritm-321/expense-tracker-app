<HistoryScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        MDTopAppBar:
            title: root.month_label
            elevation: 2
            left_action_items: [["chevron-left", lambda x: root.prev_month()]]
            right_action_items: [["chevron-right", lambda x: root.next_month()]]

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                padding: "16dp", "16dp", "16dp", "16dp"
                spacing: "8dp"

                MDLabel:
                    id: empty_label
                    text: ""
                    halign: "center"
                    theme_text_color: "Hint"
                    size_hint_y: None
                    height: "48dp"

                MDBoxLayout:
                    id: transaction_list
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "6dp"

        BottomNavBar:
            active_tab: "history"
